# ============================================================================
# Google Maps Platform
# ============================================================================

# PUBLIC browser key — Maps JavaScript API only (renders the map + markers).
# Restrict by HTTP referrer (localhost + your Vercel domain) in Cloud Console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_maps_js_browser_key_here

# SERVER keys — never exposed to the browser. One per API for clean usage
# tracking + tighter restrictions. (A single key for all three also works —
# just paste the same value into each.)
GOOGLE_PLACES_API_KEY=your_places_api_new_key_here
GOOGLE_GEOCODING_API_KEY=your_geocoding_api_key_here
GOOGLE_ROUTES_API_KEY=your_routes_api_key_here

# ============================================================================
# Supabase
# ============================================================================
# Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key_here

# SERVER-ONLY service role key. Bypasses RLS — never expose to the browser
# and never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================================================
# Outscraper (optional) — most-recent + 1★/5★ Google reviews
# ============================================================================
# The official Places API caps reviews at 5 (relevance-sorted only). Outscraper
# scrapes Google Maps so we can sort by newest and surface recent low/high
# reviews. NOTE: this is a PAID service — Outscraper requires activating API
# access (adding billing/credits) before a token works; the nominal free
# allowance is not usable without it. The app works fine without this; the
# official Google Places reviews (free) are used when this is unset.
# Get a token at outscraper.com → Profile → API/Integrations.
# SERVER-ONLY — do not prefix with NEXT_PUBLIC_.
OUTSCRAPER_API_KEY=your_outscraper_token_here

# ============================================================================
# LLM auto-fill (optional) — rent + amenities from a listing website
# ============================================================================
# Google's APIs can't return rent or amenities (gym, basketball, pool). The
# /api/extract route reads the property website and uses an LLM to fill them in.
# Set ONE of these (OpenAI is preferred; Anthropic is the fallback).
# SERVER-ONLY — do not prefix with NEXT_PUBLIC_.
OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
